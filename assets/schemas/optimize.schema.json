{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_title",
    "project_summary",
    "findings",
    "root_claude",
    "rules",
    "next_steps"
  ],
  "properties": {
    "project_title": {
      "type": "string"
    },
    "project_summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "minItems": 3,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["topic", "severity", "finding", "recommendation"],
        "properties": {
          "topic": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "finding": { "type": "string" },
          "recommendation": { "type": "string" }
        }
      }
    },
    "root_claude": {
      "type": "object",
      "additionalProperties": false,
      "required": ["goal", "instructions", "workflow", "build_test_commands", "safety"],
      "properties": {
        "goal": {
          "type": "string"
        },
        "instructions": {
          "type": "array",
          "maxItems": 7,
          "items": {
            "type": "string"
          }
        },
        "workflow": {
          "type": "array",
          "maxItems": 5,
          "items": {
            "type": "string"
          }
        },
        "build_test_commands": {
          "type": "array",
          "maxItems": 6,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "command", "status"],
            "properties": {
              "label": { "type": "string" },
              "command": { "type": "string" },
              "status": { "type": "string" }
            }
          }
        },
        "safety": {
          "type": "array",
          "maxItems": 5,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slug", "title", "why", "when_to_use", "instructions"],
        "properties": {
          "slug": { "type": "string" },
          "title": { "type": "string" },
          "why": { "type": "string" },
          "when_to_use": { "type": "string" },
          "instructions": {
            "type": "array",
            "maxItems": 6,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "next_steps": {
      "type": "array",
      "minItems": 3,
      "maxItems": 8,
      "items": {
        "type": "string"
      }
    }
  }
}
